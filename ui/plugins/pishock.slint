import { Button, LineEdit, SpinBox, TextEdit, HorizontalBox, VerticalBox } from "std-widgets.slint";
import { Overlay } from "../widgets/overlay.slint";
import { FormGroup } from "../widgets/form_group.slint";

export global PishockSettings {
    in-out property <string> username: "pishock";
    in-out property <string> api-key: "pishock";
    in-out property <int> duration: 5;
    in-out property <bool> is-dirty: false;
    in-out property <string> test-status: "";
    in-out property <bool> test-success: false;
    in-out property <bool> test-running: false;

    callback cancel();
    callback apply();
    callback okay();
    callback test();
}

export component PishockSettingsOverlay inherits Overlay {
    VerticalBox {
        padding: 16px;

        VerticalLayout {
            alignment: start;
            vertical-stretch: 1;
            spacing: 8px;

            FormGroup {
                label: "Username";

                LineEdit {
                    text <=> PishockSettings.username;
                    edited => {
                        PishockSettings.is-dirty = true;
                    }
                }
            }

            FormGroup {
                label: "API Key";

                LineEdit {
                    text <=> PishockSettings.api-key;
                    edited => {
                        PishockSettings.is-dirty = true;
                    }
                }
            }

            FormGroup {
                label: "Duration";

                SpinBox {
                    minimum: 1;
                    maximum: 10;
                    width: 150px;
                    value <=> PishockSettings.duration;
                    edited => {
                        PishockSettings.is-dirty = true;
                    }
                }
            }

            HorizontalLayout {
                spacing: 8px;
                alignment: start;
                padding-top: 8px;
                padding-left: 100px;

                Button {
                    text: PishockSettings.test-running ? "Testing…" : "Test Connection";
                    enabled: !PishockSettings.test-running;
                    clicked => {
                        PishockSettings.test()
                    }
                }

                Text {
                    text: PishockSettings.test-status;
                    color: PishockSettings.test-success ? #4caf50 : #f44336;
                    vertical-alignment: center;
                }
            }

        }

        HorizontalBox {
            padding: 0;

            Button {
                text: "Cancel";
                clicked => {
                    PishockSettings.cancel()
                }
            }

            Button {
                enabled: PishockSettings.is-dirty;
                text: "Apply";
                clicked => {
                    PishockSettings.apply()
                }
            }

            Button {
                text: "Ok";
                clicked => {
                    PishockSettings.okay()
                }
            }
        }
    }
}
